    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const credit = Number($json.Credit_Score);\nconst missed = Number($json.Missed_Payments);\nconst dti = Number($json.Debt_to_Income_Ratio);\n\nlet decision = \"\";\nlet risk = \"\";\n\nif (\n  credit >= 750 &&\n  missed === 0 &&\n  dti <= 35\n) {\n  decision = \"Approved\";\n  risk = \"Low\";\n}\nelse if (\n  credit >= 650 &&\n  credit < 750\n) {\n  decision = \"Review\";\n  risk = \"Medium\";\n}\nelse {\n  decision = \"Rejected\";\n  risk = \"High\";\n}\n\nreturn {\n  json: {\n    ...$json,\n    Decision: decision,\n    Risk_Level: risk\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
