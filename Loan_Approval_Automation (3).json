        "message": "=<h2>🎉 Loan Approved</h2>\n\n<p>Your loan application has been approved.</p>\n\n<table border=\"1\" cellpadding=\"8\">\n<tr>\n<td><b>Loan ID</b></td>\n<td>LN031</td>\n</tr>\n\n<tr>\n<td><b>Risk Level</b></td>\n<td style=\"color:green;\">Low</td>\n</tr>\n\n<tr>\n<td><b>Status</b></td>\n<td>Approved</td>\n</tr>\n</table>\n\n<br>\n\n<b>System Decision</b>\n\n<ul>\n<li>Applicant classified as low credit risk</li>\n<li>Eligible for automatic loan approval</li>\n<li>No manual intervention required</li>\n</ul>",
